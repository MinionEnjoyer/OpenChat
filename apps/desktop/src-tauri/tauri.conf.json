{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenChat",
  "version": "0.4.1",
  "identifier": "com.creeger.openchat",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../web && npm install && npm run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenChat",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["openchat"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/MinionEnjoyer/OpenChat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzRjczNjA1RjEyNTQ3QkUKUldTK1J5WHhCVGIzd3c5TWdFUzBEdGIwNEg1d2VRMCsyYVF4ajFzNEwxRWlDUHhkbGJqREF2Nm0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
