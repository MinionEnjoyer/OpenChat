# =============================================================================
#  OpenChat — configuration
#  This is the ONE config file for the whole stack. Copy it and fill it in:
#
#      cp .env.example .env      # then edit .env  (never commit .env)
#      ./scripts/setup.sh        # renders livekit.yaml from .env
#
#  Everything personal (keys, tokens, passwords, the public IP) lives in the
#  local .env only — it is gitignored and never pushed. Templates like this
#  file ARE committed, so keep real secrets OUT of here.
#  Replace every CHANGE_ME below. Generate secrets with:  openssl rand -hex 32
# =============================================================================

# ── deployment identity / hosts ──────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
WEB_ORIGIN=https://chat.example.com     # public URL users load the app from
WEB_PORT=8810                            # host port the web container binds (proxy → here)

# Service hostnames (used for server-side host pinning below). Match your domains.
CHAT_HOST=chat.example.com
AUTH_HOST=auth.example.com
SHARE_HOST=share.example.com
WATCH_HOST=watch.example.com

# LAN IP of the host running your reverse proxy. Server-side calls to the hosts
# above are pinned to this IP (public DNS points at an edge the container can't reach).
LAN_HOST_IP=192.168.1.10

# ── database (compose builds DATABASE_URL from these) ─────────────────────────
POSTGRES_USER=chat
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=chat
# For non-Docker local dev only, point at your own Postgres:
# DATABASE_URL=postgresql://chat:chat@localhost:5432/chat

# ── redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── sessions ─────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_long_random_min_16_chars

# ── auth: Authentik OIDC (from your 'chat' provider) ─────────────────────────
OIDC_ISSUER=https://auth.example.com/application/o/chat/
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URI=https://chat.example.com/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://chat.example.com

# ── file uploads: OpenShare (OPTIONAL) ───────────────────────────────────────
# Point SHARE_BASE_URL at your OpenShare instance (https://github.com/MinionEnjoyer/OpenShare)
# to enable image/file uploads, avatars, and inline embeds. On the OpenShare side, add this
# app's URL to its ALLOWED_ORIGINS. Leave both blank to run without uploads (upload UI hides).
SHARE_BASE_URL=https://share.example.com
SHARE_API_KEY=unused

# ── watch parties: Jellyfin (API key optional) ───────────────────────────────
JELLYFIN_URL=https://watch.example.com
JELLYFIN_API_KEY=

# ── voice / video: LiveKit ───────────────────────────────────────────────────
# API key/secret are shared with the LiveKit server (livekit.yaml is rendered
# from these by scripts/setup.sh — keep them in sync automatically).
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME_long_random
# HTTP URL the API uses to read LiveKit's live voice roster (self-heals ghost participants).
# Point at the LiveKit server's HTTP port, reachable from the API container. Optional.
LIVEKIT_API_URL=http://livekit.internal:7880
# Public IP that call clients reach for WebRTC media (your edge/VPS, or this host).
LIVEKIT_NODE_IP=CHANGE_ME_public_ip

# ── GIFs: Giphy (optional; picker hides itself if empty) ─────────────────────
GIPHY_API_KEY=
